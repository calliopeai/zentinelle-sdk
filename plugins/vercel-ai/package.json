{
  "name": "zentinelle-ai",
  "version": "0.1.0",
  "description": "Zentinelle integration for Vercel AI SDK - AI Agent Governance",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vercel",
    "ai",
    "ai-sdk",
    "agents",
    "governance",
    "guardrails",
    "zentinelle"
  ],
  "author": {
    "name": "Calliope Labs",
    "email": "engineering@calliope.ai"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/calliopeai/zentinelle-sdk.git"
  },
  "homepage": "https://zentinelle.ai",
  "peerDependencies": {
    "ai": ">=3.0.0",
    "zentinelle": ">=0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ai": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "zentinelle": "^0.1.0"
  }
}
